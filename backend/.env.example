# ==========================================
# SnapCook Backend Configuration
# ==========================================

# OpenAI API Key (Required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# API Authentication Key (Required)
# This is used to authenticate requests from your Flutter app
# Generate a strong random key: openssl rand -hex 32
API_KEY=your-api-key-for-flutter-app

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Environment
ENVIRONMENT=development  # development, staging, production

# Optional: Database (if you add database later)
# DATABASE_URL=postgresql://user:password@localhost/snapcook
# REDIS_URL=redis://localhost:6379/0

# Optional: Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# Optional: Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
